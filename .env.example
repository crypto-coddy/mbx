APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mbx
DB_USERNAME=root
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CORS — browser clients only (Expo web, admin SPA). Comma-separated origins.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
CORS_MAX_AGE=86400

# Security headers (CSP, X-Frame-Options, nosniff, etc.)
SECURITY_HEADERS_ENABLED=true
# SECURITY_CSP_API=
# SECURITY_CSP_ADMIN=
# SECURITY_HSTS_ENABLED=true

# QuantX
SUPER_ADMIN_PHONE=9999999999
SUPER_ADMIN_PASSWORD=password
SUPER_ADMIN_EMAIL=admin@mbxzone.test
METALS_API_KEY=

# Twelve Data — live OHLC candles (admin → Markets Live)
TWELVE_DATA_API_KEY=
TWELVE_DATA_PLAN=grow
TWELVE_DATA_MOBILE_CACHE_ONLY=true
TWELVE_DATA_QUOTE_CACHE_TTL=60
TWELVE_DATA_MOBILE_QUOTE_MAX_AGE=45
TWELVE_DATA_MOBILE_SERIES_MAX_AGE=120
TWELVE_DATA_SERIES_CACHE_TTL=300
TWELVE_DATA_CREDIT_RESERVE=40

# Reverb WebSockets
REVERB_APP_ID=mbx
REVERB_APP_KEY=mbx-reverb-key
REVERB_APP_SECRET=mbx-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# S3 / Cloudflare R2 (KYC uploads)
# AWS_ENDPOINT=https://xxx.r2.cloudflarestorage.com
